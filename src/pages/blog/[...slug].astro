---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layout/PageLayout.astro";
import PostHeader from "../../components/PostHeader.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import { getBlogCoverImage } from "../../utils/blog-cover";
import { getEntrySlug } from "../../utils/content";
import { getISODate } from "../../utils/date";
import { getReadingTime } from "../../utils/reading-time";
import { AUTHOR, SITE_URL } from "../../config";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => post.data.published)
    .map((post) => ({
      params: { slug: getEntrySlug(post) },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = getEntrySlug(post);

const publishedISO = getISODate(post.data.date);
const modifiedISO = post.data.modified
  ? getISODate(post.data.modified)
  : publishedISO;
const readingTime = getReadingTime(post.body || "");
const coverImage = getBlogCoverImage(post.data.image, slug);

// Find related posts by matching tags
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter(
    (p) =>
      getEntrySlug(p) !== slug &&
      p.data.published &&
      p.data.tags.some((t) => post.data.tags.includes(t))
  )
  .slice(0, 2)
  .map((p) => ({ title: p.data.title, slug: getEntrySlug(p), date: p.data.date }));

const blogPostSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  author: {
    "@type": "Person",
    name: AUTHOR.name,
    url: SITE_URL,
    sameAs: [
      `https://github.com/${AUTHOR.github}`,
      `https://x.com/${AUTHOR.twitter}`,
    ],
  },
  publisher: {
    "@type": "Person",
    name: AUTHOR.name,
    url: SITE_URL,
  },
  datePublished: publishedISO,
  dateModified: modifiedISO,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${SITE_URL}/blog/${slug}`,
  },
  url: `${SITE_URL}/blog/${slug}`,
  image: `${SITE_URL}${coverImage}`,
  keywords: post.data.tags.join(", "),
  wordCount: (post.body || "").split(/\s+/).length,
  articleSection: "Blog",
  inLanguage: "en-US",
};
---

<PageLayout
  title={post.data.title}
  description={post.data.description || `Read ${post.data.title} by ${AUTHOR.name}`}
  canonical={`${SITE_URL}/blog/${slug}`}
  image={coverImage}
  type="article"
  publishedTime={publishedISO}
  modifiedTime={modifiedISO}
  keywords={post.data.tags.join(", ") || "Blog, Programming, Technology"}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(blogPostSchema)}
  />

  <article itemscope itemtype="https://schema.org/BlogPosting" class="py-8">
    <meta itemprop="author" content={AUTHOR.name} />
    <meta itemprop="datePublished" content={publishedISO} />
    <meta itemprop="dateModified" content={modifiedISO} />

    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Blog", href: "/blog" },
        { label: post.data.title },
      ]}
    />

    <PostHeader
      title={post.data.title}
      date={post.data.date}
      readingTime={readingTime}
      tags={post.data.tags}
      publishedISO={publishedISO}
      image={coverImage}
    />

    <div
      class="prose prose-lg
        text-md text-left min-w-full
        prose-headings:font-display prose-headings:font-normal
        prose-headings:text-text-primary
        prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg
        prose-strong:text-primary-400 prose-strong:font-semibold
        prose-img:rounded-xl prose-img:mx-auto
        prose-img:border prose-img:border-border-default
        prose-a:bg-bg-elevated/50 prose-a:px-1 prose-a:py-0.5 prose-a:rounded
        prose-a:text-primary-400 prose-a:no-underline
        prose-a:hover:bg-bg-elevated prose-a:hover:text-primary-300
        prose-a:transition-colors
        prose-p:text-text-secondary prose-p:leading-relaxed
        prose-blockquote:border-l-primary-500
        prose-li:text-text-secondary
        prose-code:font-code prose-code:text-text-secondary
        prose-code:before:content-[''] prose-code:after:content-['']
        prose-pre:font-code prose-pre:bg-bg-elevated prose-pre:border prose-pre:border-border-default
      "
      itemprop="articleBody"
    >
      <Content />
    </div>

    <RelatedPosts posts={relatedPosts} />
  </article>
</PageLayout>
