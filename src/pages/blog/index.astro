---
import PageLayout from "../../layout/PageLayout.astro";
import BlogHeroCard from "../../components/BlogHeroCard.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import { parseDate } from "../../utils/date";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((post) => post.data.published)
  .sort((a, b) => parseDate(b.data.date).getTime() - parseDate(a.data.date).getTime());

const [heroPost, ...restPosts] = posts;
---

<PageLayout
  title="Blog"
  description="Articles about programming, systems design, and the web by Raj Patel"
  keywords="Blog, Programming, Systems Design, Software Development, Technical Writing"
  wide
>
  <section class="py-8">
    <div class="mb-10">
      <h1 class="text-5xl md:text-6xl font-display text-text-primary mb-3">Blog</h1>
      <p class="text-lg text-text-muted">
        Thoughts on programming, systems, and the craft of building software
      </p>
    </div>

    {heroPost && (
      <div class="mb-10">
        <BlogHeroCard
          title={heroPost.data.title}
          description={heroPost.data.description}
          date={heroPost.data.date}
          tags={heroPost.data.tags}
          slug={heroPost.slug}
          body={heroPost.body}
          image={heroPost.data.image}
        />
      </div>
    )}

    {restPosts.length > 0 && (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {restPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
            body={post.body}
            image={post.data.image}
          />
        ))}
      </div>
    )}

    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-text-muted text-lg">No posts yet. Check back soon!</p>
      </div>
    )}
  </section>
</PageLayout>
