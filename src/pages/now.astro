---
import PageLayout from "../layout/PageLayout.astro";

const readingNow = [
  {
    title: "Who Rules the World?",
    author: "Noam Chomsky",
    note: "Power, institutions, and the stories nations tell about themselves.",
  },
  {
    title: "Situational Awareness",
    author: "Leopold Aschenbrenner",
    note: "Ongoing notes on AI progress, timelines, and strategic pressure.",
  },
  {
    title: "Poor Charlie's Almanack",
    author: "Charlie Munger",
    note: "Mental models, judgment, incentives, and practical worldly wisdom.",
  },
  {
    title: "The Idiot",
    author: "Fyodor Dostoevsky",
    note: "A slower fiction counterweight to the strategy and markets shelf.",
  },
];

const wantToRead = [
  "Fooled by Randomness",
  "The Intelligent Investor",
  "Siddhartha",
];

const watchlist = [
  "Obsession",
  "Full Metal Jacket",
  "Barry Lyndon",
  "The Killing",
  "Lolita",
  "Midnight in Paris",
  "In the Mood for Love",
  "More by Wong Kar-wai",
];

const recentlyWatched = [
  {
    title: "Eyes Wide Shut",
    note: "Strange, controlled, and interesting. The Stanley Kubrick thread continues.",
  },
  {
    title: "Amadeus",
    note: "Large, theatrical, and still oddly intimate.",
  },
  {
    title: "The Truman Show",
    note: "A clean idea that keeps getting sharper with time.",
  },
];
---

<PageLayout
  title="Now"
  description="A snapshot of what Raj is reading, watching, and thinking about right now."
  keywords="Raj Patel, Now page, Reading, Movies, Books, Personal website"
  wide
>
  <section class="now-shell py-10 md:py-14">
    <div class="now-hero">
      <div class="now-kicker">
        <span class="now-pulse" aria-hidden="true"></span>
        <span>Updated May 2026</span>
      </div>
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
        <div>
          <h1 class="font-display text-6xl md:text-7xl text-text-primary">
            /now
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed text-text-secondary">
            A small public ledger of what has my attention right now: the books
            open on the desk, films queued for late nights, and a few recent
            impressions still hanging around.
          </p>
        </div>
        <div class="now-note">
          <p class="font-mono text-xs uppercase text-primary-500">Current bias</p>
          <p class="mt-3 text-text-secondary">
            Systems of power, probability, value investing, morally complicated
            fiction, and directors who make every frame feel deliberate.
          </p>
        </div>
      </div>
    </div>

    <div class="now-grid mt-10">
      <section class="now-panel now-panel-large">
        <div class="now-panel-header">
          <p class="font-mono text-xs uppercase text-primary-500">Reading</p>
          <span>{readingNow.length} open threads</span>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {readingNow.map((book, index) => (
            <article class="now-book" style={`--i: ${index + 1}`}>
              <div class="now-book-index">0{index + 1}</div>
              <div>
                <h2 class="font-display text-2xl text-text-primary">{book.title}</h2>
                <p class="mt-1 text-sm text-text-muted">{book.author}</p>
                <p class="mt-4 text-sm leading-relaxed text-text-tertiary">{book.note}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <aside class="now-panel now-stack">
        <div>
          <p class="font-mono text-xs uppercase text-primary-500">Want to read</p>
          <div class="mt-5 space-y-3">
            {wantToRead.map((book) => (
              <div class="now-chip">{book}</div>
            ))}
          </div>
        </div>
        <div class="now-divider"></div>
        <div>
          <p class="font-mono text-xs uppercase text-primary-500">Why this page</p>
          <p class="mt-3 text-sm leading-relaxed text-text-tertiary">
            Inspired by Derek Sivers' now page idea: less archive, more present
            tense.
          </p>
        </div>
      </aside>

      <section class="now-panel now-cinema">
        <div class="now-panel-header">
          <p class="font-mono text-xs uppercase text-primary-500">Cinema queue</p>
          <span>watchlist</span>
        </div>
        <div class="now-marquee mt-6" aria-label="Movie watchlist">
          {watchlist.map((movie) => (
            <span>{movie}</span>
          ))}
        </div>
      </section>

      <section class="now-panel now-panel-large">
        <div class="now-panel-header">
          <p class="font-mono text-xs uppercase text-primary-500">Recently watched</p>
          <span>notes</span>
        </div>
        <div class="mt-6 space-y-4">
          {recentlyWatched.map((movie) => (
            <article class="now-film">
              <h2 class="font-display text-2xl text-text-primary">{movie.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-text-tertiary">{movie.note}</p>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</PageLayout>

<style>
  .now-shell {
    position: relative;
  }

  .now-shell::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 16% 12%, rgba(204, 125, 58, 0.14), transparent 28rem),
      linear-gradient(rgba(240, 236, 232, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(240, 236, 232, 0.02) 1px, transparent 1px);
    background-size: auto, 44px 44px, 44px 44px;
    mask-image: linear-gradient(to bottom, black, transparent 76%);
    z-index: -1;
  }

  .now-hero {
    border-bottom: 1px solid theme("colors.border-default");
    padding-bottom: 2.5rem;
  }

  .now-kicker,
  .now-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .now-kicker {
    justify-content: flex-start;
    margin-bottom: 1.5rem;
    color: theme("colors.text-muted");
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
  }

  .now-pulse {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: theme("colors.primary.500");
    box-shadow: 0 0 0 0 rgba(204, 125, 58, 0.45);
    animation: pulse 2.4s infinite;
  }

  .now-note,
  .now-panel {
    border: 1px solid theme("colors.border-default");
    background: rgba(18, 21, 28, 0.62);
    backdrop-filter: blur(14px);
  }

  .now-note {
    border-radius: 8px;
    padding: 1.25rem;
  }

  .now-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.55fr);
    gap: 1rem;
  }

  .now-panel {
    border-radius: 8px;
    padding: 1.25rem;
  }

  .now-panel-large {
    min-height: 18rem;
  }

  .now-panel-header span {
    color: theme("colors.text-muted");
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .now-book,
  .now-film {
    border: 1px solid theme("colors.border-default");
    border-radius: 8px;
    background: rgba(10, 12, 16, 0.42);
  }

  .now-book {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    gap: 1rem;
    padding: 1rem;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .now-book:hover,
  .now-film:hover {
    border-color: theme("colors.primary.500");
  }

  .now-book:hover {
    transform: translateY(-2px);
  }

  .now-book-index {
    color: theme("colors.primary.500");
    font-family: "Iosevka", monospace;
    font-size: 0.78rem;
    opacity: calc(0.42 + (var(--i) * 0.11));
  }

  .now-stack {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .now-chip {
    border-left: 2px solid theme("colors.primary.500");
    background: theme("colors.bg-elevated");
    color: theme("colors.text-secondary");
    padding: 0.75rem 0.85rem;
    font-size: 0.92rem;
  }

  .now-divider {
    height: 1px;
    background: theme("colors.border-default");
  }

  .now-cinema {
    overflow: hidden;
  }

  .now-marquee {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .now-marquee span {
    border: 1px solid theme("colors.border-default");
    border-radius: 999px;
    color: theme("colors.text-secondary");
    padding: 0.45rem 0.75rem;
    font-size: 0.86rem;
    background: rgba(26, 30, 40, 0.72);
  }

  .now-film {
    padding: 1rem;
  }

  @keyframes pulse {
    70% {
      box-shadow: 0 0 0 10px rgba(204, 125, 58, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(204, 125, 58, 0);
    }
  }

  @media (max-width: 820px) {
    .now-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
