---
import PageLayout from "../../layout/PageLayout.astro";
import { getCollection } from "astro:content";
import { parseDate } from "../../utils/date";

const allPosts = await getCollection("misc");
const posts = allPosts
  .filter((post) => post.data.published)
  .sort((a, b) => parseDate(b.data.date).getTime() - parseDate(a.data.date).getTime());
---

<PageLayout title="Misc.">
  <section class="py-8">
    <div class="mb-8">
      <h1 class="text-5xl font-display text-text-primary mb-3">Miscellaneous</h1>
      <p class="text-lg text-text-muted">Random thoughts, poems, and quotes I find interesting</p>
    </div>

    <ul class="space-y-3">
      {posts.map((post) => (
        <li>
          <a
            href={`/misc/${post.slug}`}
            class="group flex items-center gap-4 p-4 rounded-xl border border-border-default hover:border-primary-500/50 transition-all"
          >
            <span class="font-display text-xl text-text-primary group-hover:text-primary-400 transition-colors">
              {post.data.title}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</PageLayout>
