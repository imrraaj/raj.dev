---
interface Props {
  tag: string;
  linked?: boolean;
}

const { tag, linked = false } = Astro.props;
---

{linked ? (
  <a
    href={`/blog/tag/${tag.toLowerCase()}`}
    class="px-2.5 py-1 text-xs font-mono bg-bg-elevated text-text-tertiary rounded-md border border-border-default hover:border-primary-500 hover:text-primary-500 transition-colors"
  >
    {tag}
  </a>
) : (
  <span class="px-2.5 py-1 text-xs font-mono bg-bg-elevated text-text-tertiary rounded-md border border-border-default">
    {tag}
  </span>
)}
