---
import { formatDate } from "../utils/date";

interface RelatedPost {
  title: string;
  slug: string;
  date: string;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-16 pt-10 border-t border-border-default">
    <h2 class="font-display text-2xl text-text-primary mb-6">You might also enjoy</h2>
    <div class="grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}`}
          class="group block p-5 border border-border-default rounded-xl hover:border-primary-500/50 transition-all"
        >
          <p class="text-xs font-mono text-text-muted mb-2">{formatDate(post.date)}</p>
          <h3 class="font-display text-lg text-text-primary group-hover:text-primary-400 transition-colors">
            {post.title}
          </h3>
        </a>
      ))}
    </div>
  </section>
)}
