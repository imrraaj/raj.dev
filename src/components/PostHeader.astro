---
import TagBadge from "./TagBadge.astro";
import { formatDateLong } from "../utils/date";

interface Props {
  title: string;
  date: string;
  readingTime: number;
  tags?: string[];
  publishedISO: string;
  image?: string;
}

const { title, date, readingTime, tags = [], publishedISO, image } = Astro.props;
const coverImage = image || "/blog-cover.png";
---

<header class="mb-10">
  <div class="relative rounded-2xl overflow-hidden mb-8">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-72 md:h-96 object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/20"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
      <h1
        class="font-display text-4xl md:text-5xl text-white leading-tight mb-4 drop-shadow-lg"
        itemprop="headline"
      >
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-white/70 mb-4">
        <time datetime={publishedISO} itemprop="datePublished">
          {formatDateLong(date)}
        </time>
        <span class="text-white/40">&#183;</span>
        <span>{readingTime} min read</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      )}
    </div>
  </div>
</header>
