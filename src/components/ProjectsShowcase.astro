---
import Section from "./Section.astro";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured).slice(0, 3);
---

<Section title="Selected Work" viewAllLink="/projects" viewAllText="All projects">
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {featured.map((project) => (
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="group block p-6 border border-border-default rounded-xl bg-bg-surface/50 hover:border-primary-500/50 transition-all"
      >
        <h3 class="font-display text-xl text-text-primary group-hover:text-primary-400 transition-colors mb-2">
          {project.title}
        </h3>
        <p class="text-sm text-text-muted mb-4">{project.description}</p>
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="px-2 py-0.5 text-xs font-mono bg-bg-elevated text-text-tertiary rounded border border-border-default">
              {tech}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Section>
