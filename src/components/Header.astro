---
import NavLink from "./NavLink.astro";
import { NAVIGATION, SOCIALS, AUTHOR } from "../config";
---

<header class="px-4 sticky top-0 z-50 relative backdrop-blur-md border-b border-border-default">
  <div class="flex items-center justify-between py-4">
    <a href="/" class="flex shrink-0 items-center gap-3 group">
      <img
        class="w-10 h-10 rounded-full ring-2 ring-border-default group-hover:ring-primary-500 transition-all"
        src="/header.jpg"
        alt={`Photo of ${AUTHOR.name}`}
        width="40"
        height="40"
      />
      <span class="font-display text-xl text-text-primary whitespace-nowrap">{AUTHOR.name}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-4 lg:gap-6">
      {NAVIGATION.map((el) => (
        <NavLink href={el.link}>{el.text}</NavLink>
      ))}
      <div class="hidden lg:flex items-center gap-1 ml-2 border-l border-border-default pl-4">
        {SOCIALS.map((social) => (
          <a
            href={social.link}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 text-text-muted hover:text-primary-500 transition-colors rounded-lg hover:bg-bg-surface"
            aria-label={social.name}
          >
            {social.icon === "mail" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            )}
            {social.icon === "github" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            )}
            {social.icon === "twitter" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            )}
          </a>
        ))}
      </div>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-muted hover:text-text-primary transition-colors"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="menu-icon"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="close-icon" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="hidden absolute left-0 right-0 top-full md:hidden border-t border-border-default bg-bg-base/95 px-4 pb-4 pt-4 shadow-xl shadow-black/20 backdrop-blur-md"
  >
    <div class="flex flex-col gap-3">
      {NAVIGATION.map((el) => (
        <NavLink href={el.link}>{el.text}</NavLink>
      ))}
    </div>
    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-border-default">
      {SOCIALS.map((social) => (
        <a
          href={social.link}
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 text-text-muted hover:text-primary-500 transition-colors"
          aria-label={social.name}
        >
          {social.icon === "mail" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          )}
          {social.icon === "github" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          )}
          {social.icon === "twitter" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          )}
        </a>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  btn.addEventListener('click', () => {
    const isOpen = !nav.classList.contains('hidden');
    nav.classList.toggle('hidden');
    menuIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });
</script>
