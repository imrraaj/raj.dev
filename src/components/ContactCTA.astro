---
import { AUTHOR } from "../config";
---

<section class="py-16">
  <div class="border border-border-default rounded-2xl p-8 md:p-12 bg-bg-surface/50 flex flex-col md:flex-row md:items-start md:justify-between gap-8">
    <div>
      <h2 class="font-display text-3xl md:text-4xl text-text-primary mb-4">
        Get in Touch
      </h2>
      <p class="text-text-muted max-w-md">
        I'm always open to interesting conversations, collaborations, and opportunities.
      </p>
    </div>
    <div class="flex flex-col gap-3 flex-shrink-0 min-w-[280px]">
      <!-- Email with copy -->
      <button
        id="copy-email-btn"
        data-email={AUTHOR.email}
        class="group flex items-center justify-between px-4 py-3 border border-border-default rounded-lg hover:border-primary-500 transition-colors text-left"
      >
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors" id="email-label">Email</span>
        </div>
        <!-- Copy icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted group-hover:text-primary-500 transition-colors" id="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        <!-- Check icon (hidden by default) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400 hidden" id="check-icon"><polyline points="20 6 9 17 4 12"/></svg>
      </button>

      <!-- GitHub -->
      <a
        href={`https://github.com/${AUTHOR.github}`}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-between px-4 py-3 border border-border-default rounded-lg hover:border-primary-500 transition-colors"
      >
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">GitHub</span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted group-hover:text-primary-500 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>

      <!-- X / Twitter -->
      <a
        href={`https://x.com/${AUTHOR.twitter}`}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-between px-4 py-3 border border-border-default rounded-lg hover:border-primary-500 transition-colors"
      >
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          <span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">X</span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted group-hover:text-primary-500 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>
    </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('copy-email-btn').addEventListener('click', function() {
    const email = this.dataset.email;
    navigator.clipboard.writeText(email).then(() => {
      document.getElementById('copy-icon').classList.add('hidden');
      document.getElementById('check-icon').classList.remove('hidden');
      document.getElementById('email-label').textContent = 'Copied!';
      setTimeout(() => {
        document.getElementById('copy-icon').classList.remove('hidden');
        document.getElementById('check-icon').classList.add('hidden');
        document.getElementById('email-label').textContent = email;
      }, 2000);
    });
  });
</script>
