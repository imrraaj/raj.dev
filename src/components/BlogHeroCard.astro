---
import TagBadge from "./TagBadge.astro";
import { formatDate } from "../utils/date";
import { getBlogCoverImage } from "../utils/blog-cover";
import { getReadingTime } from "../utils/reading-time";

interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
  slug: string;
  body?: string;
  image?: string;
}

const { title, description, date, tags = [], slug, body = "", image } = Astro.props;
const readingTime = getReadingTime(body);
const coverImage = getBlogCoverImage(image, slug || title);
---

<article class="group relative border border-border-default rounded-2xl overflow-hidden bg-bg-surface hover:border-primary-500/50 transition-all duration-300">
  <div class="absolute top-4 right-4 z-10">
    <span class="text-xs font-mono uppercase tracking-wider text-primary-500 bg-primary-500/10 backdrop-blur-sm px-3 py-1 rounded-full">
      Latest
    </span>
  </div>
  <a href={`/blog/${slug}`} class="block">
    <div class="relative h-48 md:h-64 overflow-hidden">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-bg-surface via-bg-surface/60 to-transparent"></div>
    </div>
    <div class="p-8 md:p-10 -mt-16 relative">
      <div class="flex items-center gap-3 mb-4">
        <time datetime={date} class="text-sm font-mono text-text-muted">
          {formatDate(date)}
        </time>
        <span class="text-text-disabled">&#183;</span>
        <span class="text-sm font-mono text-text-muted">{readingTime} min read</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl text-text-primary group-hover:text-primary-400 transition-colors mb-4">
        {title}
      </h2>
      {description && (
        <p class="text-text-secondary text-lg max-w-2xl mb-6">{description}</p>
      )}
    </div>
  </a>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 px-8 md:px-10 pb-8">
      {tags.map((tag) => <TagBadge tag={tag} />)}
    </div>
  )}
</article>
